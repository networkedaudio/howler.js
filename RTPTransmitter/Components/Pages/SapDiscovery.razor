@page "/sapdiscovery"
@rendermode InteractiveServer
@using RTPTransmitter.Services
@using RTPTransmitter.Components.Shared
@inject SapStreamRegistry Registry
@inject RtpStreamManager StreamManager
@inject NetworkInterfaceService NicService
@inject IDialogService DialogService
@inject IJSRuntime JS
@implements IDisposable

<PageTitle>SAP Stream Discovery</PageTitle>

<h2>SAP Stream Discovery</h2>

<div class="card mb-4">
    <div class="card-body">
        <h5 class="card-title mb-3">Network Interface</h5>
        <div class="d-flex align-items-center gap-3">
            <MudSelect T="string" Label="Select NIC for multicast" Variant="Variant.Outlined"
                       Value="selectedNic" ValueChanged="OnNicSelected"
                       AnchorOrigin="Origin.BottomCenter" Dense="true" Style="max-width: 600px;">
                @foreach (var nic in availableNics)
                {
                    <MudSelectItem T="string" Value="@nic.IpAddress">
                        @nic.DisplayName
                        @if (!nic.SupportsMulticast)
                        {
                            <text> (no multicast)</text>
                        }
                    </MudSelectItem>
                }
            </MudSelect>
            <MudIconButton Icon="@Icons.Material.Filled.Refresh" Size="Size.Medium"
                           OnClick="RefreshNics" Title="Refresh NIC list" />
            @if (!string.IsNullOrEmpty(selectedNic) && selectedNic != "0.0.0.0")
            {
                <MudChip T="string" Color="Color.Success" Size="Size.Small">@selectedNic</MudChip>
            }
            else
            {
                <MudChip T="string" Color="Color.Warning" Size="Size.Small">No NIC selected</MudChip>
            }
        </div>
    </div>
</div>

@* ── SDP File Upload ── *@
<MudPaper Elevation="1" Class="pa-4 mb-4">
    <div class="d-flex align-items-center gap-3 mb-2">
        <MudIcon Icon="@Icons.Material.Filled.UploadFile" />
        <MudText Typo="Typo.h6">Import SDP File</MudText>
    </div>
    <MudText Typo="Typo.body2" Class="mb-3">
        Upload an <code>.sdp</code> text file to manually add a stream to the discovery table.
    </MudText>
    <div class="d-flex align-items-center gap-3">
        <MudFileUpload T="IBrowserFile" Accept=".sdp,.txt" FilesChanged="OnSdpFileUploaded" MaximumFileCount="1">
            <ActivatorContent>
                <MudButton Variant="Variant.Filled" Color="Color.Primary"
                           StartIcon="@Icons.Material.Filled.CloudUpload">
                    Choose SDP File
                </MudButton>
            </ActivatorContent>
        </MudFileUpload>
        @if (!string.IsNullOrEmpty(uploadStatus))
        {
            <MudChip T="string" Color="@uploadStatusColor" Size="Size.Small">@uploadStatus</MudChip>
        }
    </div>
</MudPaper>

@* ── Discovered Streams Table ── *@
<MudPaper Elevation="1" Class="pa-4 mb-4">
    <div class="d-flex justify-content-between align-items-center mb-3">
        <MudText Typo="Typo.h6">Discovered Streams (@streams.Count)</MudText>
        <MudIconButton Icon="@Icons.Material.Filled.Refresh" Size="Size.Small"
                       OnClick="() => RefreshStreams()" Title="Refresh" />
    </div>

    @if (streams.Count == 0)
    {
        <MudAlert Severity="Severity.Info" Variant="Variant.Outlined" Dense="true">
            <strong>Listening for SAP announcements…</strong><br />
            No AES67/SAP streams have been discovered yet. Streams will appear automatically as they are announced,
            or you can import an SDP file above.
        </MudAlert>
    }
    else
    {
        <MudTable Items="@streams" Dense="true" Hover="true" Bordered="true" Striped="true"
                  Breakpoint="Breakpoint.Sm" RowClass="align-middle">
            <HeaderContent>
                <MudTh>Name</MudTh>
                <MudTh>Multicast</MudTh>
                <MudTh>Port</MudTh>
                <MudTh>Codec</MudTh>
                <MudTh>Rate</MudTh>
                <MudTh>Ch</MudTh>
                <MudTh>Bits</MudTh>
                <MudTh>ptime</MudTh>
                <MudTh>Source</MudTh>
                <MudTh>Last Seen</MudTh>
                <MudTh Style="text-align:center;">SDP</MudTh>
                <MudTh Style="text-align:center;">Action</MudTh>
            </HeaderContent>
            <RowTemplate>
                <MudTd DataLabel="Name">
                    <strong>@context.Name</strong>
                    @if (!string.IsNullOrEmpty(context.Description))
                    {
                        <br /><MudText Typo="Typo.caption" Color="Color.Secondary">@context.Description</MudText>
                    }
                    @if (context.IsManual)
                    {
                        <MudChip T="string" Size="Size.Small" Color="Color.Info" Class="ml-1">Uploaded</MudChip>
                    }
                </MudTd>
                <MudTd DataLabel="Multicast"><code>@context.MulticastGroup</code></MudTd>
                <MudTd DataLabel="Port">@context.Port</MudTd>
                <MudTd DataLabel="Codec"><MudChip T="string" Size="Size.Small" Color="Color.Info">@context.Codec</MudChip></MudTd>
                <MudTd DataLabel="Rate">@(context.SampleRate / 1000)k</MudTd>
                <MudTd DataLabel="Ch">@context.Channels</MudTd>
                <MudTd DataLabel="Bits">@context.BitDepth</MudTd>
                <MudTd DataLabel="ptime">@(context.PtimeMs > 0 ? $"{context.PtimeMs}ms" : "—")</MudTd>
                <MudTd DataLabel="Source"><MudText Typo="Typo.caption">@context.OriginatingSource</MudText></MudTd>
                <MudTd DataLabel="Last Seen"><MudText Typo="Typo.caption">@FormatAge(context.LastSeen)</MudText></MudTd>
                <MudTd DataLabel="SDP" Style="text-align:center;">
                    <MudIconButton Icon="@Icons.Material.Filled.Description"
                                   Size="Size.Small" Color="Color.Default"
                                   OnClick="() => ShowSdpDialog(context)"
                                   Title="View SDP" />
                </MudTd>
                <MudTd DataLabel="Action" Style="text-align:center;">
                    @{ bool isActive = StreamManager.IsActive(context.Id); }
                    @if (isActive)
                    {
                        <div class="d-flex gap-1 justify-center">
                            <MudChip T="string" Size="Size.Small" Color="Color.Success">● Listening</MudChip>
                            <MudButton Variant="Variant.Outlined" Color="Color.Error" Size="Size.Small"
                                       OnClick="() => StopStream(context.Id)" Disabled="isProcessing">
                                Stop
                            </MudButton>
                            <MudButton Variant="Variant.Outlined" Color="Color.Primary" Size="Size.Small"
                                       Href="@($"audiostream?stream={context.Id}")">
                                Open Player
                            </MudButton>
                        </div>
                    }
                    else
                    {
                        <MudButton Variant="Variant.Filled" Color="Color.Primary" Size="Size.Small"
                                   OnClick="() => StartStream(context)" Disabled="isProcessing"
                                   StartIcon="@Icons.Material.Filled.PlayArrow">
                            Listen
                        </MudButton>
                    }
                </MudTd>
            </RowTemplate>
        </MudTable>
    }
</MudPaper>

@* ── Active Listeners Table ── *@
@if (activeStreams.Count > 0)
{
    <MudPaper Elevation="1" Class="pa-4 mb-4">
        <MudText Typo="Typo.h6" Class="mb-3">Active Listeners (@activeStreams.Count)</MudText>
        <MudTable Items="@activeStreams" Dense="true" Hover="true" Bordered="true"
                  Breakpoint="Breakpoint.Sm">
            <HeaderContent>
                <MudTh>Name</MudTh>
                <MudTh>Multicast</MudTh>
                <MudTh>Port</MudTh>
                <MudTh>Format</MudTh>
                <MudTh>Since</MudTh>
                <MudTh Style="text-align:center;">Actions</MudTh>
            </HeaderContent>
            <RowTemplate>
                <MudTd DataLabel="Name"><strong>@context.Name</strong></MudTd>
                <MudTd DataLabel="Multicast"><code>@context.MulticastGroup</code></MudTd>
                <MudTd DataLabel="Port">@context.Port</MudTd>
                <MudTd DataLabel="Format">@(context.BitDepth)bit / @(context.SampleRate / 1000)kHz / @(context.Channels)ch</MudTd>
                <MudTd DataLabel="Since"><MudText Typo="Typo.caption">@FormatAge(context.StartedAt)</MudText></MudTd>
                <MudTd DataLabel="Actions" Style="text-align:center;">
                    <div class="d-flex gap-1 justify-center">
                        <MudButton Variant="Variant.Outlined" Color="Color.Primary" Size="Size.Small"
                                   Href="@($"audiostream?stream={context.StreamId}")">
                            Open Player
                        </MudButton>
                        <MudButton Variant="Variant.Outlined" Color="Color.Error" Size="Size.Small"
                                   OnClick="() => StopStream(context.StreamId)" Disabled="isProcessing">
                            Stop
                        </MudButton>
                    </div>
                </MudTd>
            </RowTemplate>
        </MudTable>
    </MudPaper>
}

@code {
    private List<DiscoveredStream> streams = new();
    private List<RtpStreamManager.ActiveStream> activeStreams = new();
    private bool isProcessing;
    private System.Threading.Timer? refreshTimer;

    private IReadOnlyList<NicInfo> availableNics = [];
    private string selectedNic = "0.0.0.0";

    // SDP file upload state
    private string? uploadStatus;
    private Color uploadStatusColor = Color.Default;

    protected override void OnInitialized()
    {
        // Load available NICs and current selection
        availableNics = NicService.GetAvailableInterfaces();
        selectedNic = NicService.SelectedAddress;

        RefreshStreams();

        // Subscribe to registry changes
        Registry.OnStreamsChanged += OnRegistryChanged;

        // Auto-refresh every 5 seconds for age display and active stream status
        refreshTimer = new System.Threading.Timer(_ =>
        {
            InvokeAsync(() =>
            {
                RefreshStreams();
                StateHasChanged();
            });
        }, null, TimeSpan.FromSeconds(5), TimeSpan.FromSeconds(5));
    }

    private void OnNicSelected(string ipAddress)
    {
        selectedNic = ipAddress;
        NicService.Select(ipAddress);
    }

    private void RefreshNics()
    {
        availableNics = NicService.GetAvailableInterfaces();
    }

    private void OnRegistryChanged()
    {
        InvokeAsync(() =>
        {
            RefreshStreams();
            StateHasChanged();
        });
    }

    private void RefreshStreams()
    {
        streams = Registry.GetAll().ToList();
        activeStreams = StreamManager.GetActiveStreams().ToList();
    }

    // ── SDP Viewer Dialog ──

    private async Task ShowSdpDialog(DiscoveredStream stream)
    {
        var parameters = new DialogParameters<SdpViewerDialog>
        {
            { x => x.Stream, stream }
        };

        var options = new DialogOptions
        {
            MaxWidth = MaxWidth.Medium,
            FullWidth = true,
            CloseOnEscapeKey = true
        };

        await DialogService.ShowAsync<SdpViewerDialog>("SDP Viewer", parameters, options);
    }

    // ── SDP File Upload ──

    private async Task OnSdpFileUploaded(IBrowserFile file)
    {
        uploadStatus = null;

        try
        {
            if (file.Size > 64 * 1024)
            {
                uploadStatus = "File too large (max 64 KB)";
                uploadStatusColor = Color.Error;
                return;
            }

            using var reader = new StreamReader(file.OpenReadStream(maxAllowedSize: 64 * 1024));
            var sdpText = await reader.ReadToEndAsync();

            if (string.IsNullOrWhiteSpace(sdpText))
            {
                uploadStatus = "File is empty";
                uploadStatusColor = Color.Error;
                return;
            }

            var sdp = SdpParser.Parse(sdpText);
            if (sdp == null || !sdp.IsValidAudioStream)
            {
                uploadStatus = "Invalid SDP — no valid audio stream found";
                uploadStatusColor = Color.Error;
                return;
            }

            // Create a unique ID for the manually-added stream
            var manualId = $"manual:{sdp.SessionName}:{sdp.MulticastAddress}:{sdp.Port}";

            var stream = new DiscoveredStream
            {
                Id = manualId,
                Name = !string.IsNullOrWhiteSpace(sdp.SessionName) ? sdp.SessionName : file.Name,
                Description = sdp.SessionDescription,
                MulticastGroup = sdp.MulticastAddress,
                SourceAddress = sdp.SourceAddress,
                Port = sdp.Port,
                SampleRate = sdp.SampleRate,
                Channels = sdp.Channels,
                BitDepth = sdp.BitDepth,
                PayloadType = sdp.PayloadType,
                Codec = sdp.Codec,
                PtimeMs = sdp.PtimeMs,
                OriginatingSource = "File upload",
                Origin = sdp.Origin,
                RawSdp = sdp.RawSdp,
                ChannelLabels = sdp.ChannelLabels,
                IsManual = true,
                LastSeen = DateTimeOffset.UtcNow
            };

            Registry.AddOrUpdate(stream);
            RefreshStreams();

            uploadStatus = $"Added \"{stream.Name}\"";
            uploadStatusColor = Color.Success;
        }
        catch (Exception ex)
        {
            uploadStatus = $"Error: {ex.Message}";
            uploadStatusColor = Color.Error;
        }
    }

    // ── Stream Control ──

    private async Task StartStream(DiscoveredStream stream)
    {
        isProcessing = true;
        try
        {
            StreamManager.StartListening(stream);
            RefreshStreams();
        }
        catch (Exception ex)
        {
            Console.Error.WriteLine($"Error starting stream: {ex.Message}");
        }
        finally
        {
            isProcessing = false;
        }
    }

    private async Task StopStream(string streamId)
    {
        isProcessing = true;
        try
        {
            await StreamManager.StopListening(streamId, force: true);
            RefreshStreams();
        }
        catch (Exception ex)
        {
            Console.Error.WriteLine($"Error stopping stream: {ex.Message}");
        }
        finally
        {
            isProcessing = false;
        }
    }

    private static string FormatAge(DateTimeOffset time)
    {
        var age = DateTimeOffset.UtcNow - time;
        if (age.TotalSeconds < 60) return $"{(int)age.TotalSeconds}s ago";
        if (age.TotalMinutes < 60) return $"{(int)age.TotalMinutes}m ago";
        return $"{(int)age.TotalHours}h {age.Minutes}m ago";
    }

    public void Dispose()
    {
        Registry.OnStreamsChanged -= OnRegistryChanged;
        refreshTimer?.Dispose();
    }
}
