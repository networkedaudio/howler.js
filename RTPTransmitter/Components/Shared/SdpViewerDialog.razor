@using RTPTransmitter.Services

<MudDialog>
    <TitleContent>
        <div class="d-flex align-items-center gap-2">
            <MudIcon Icon="@Icons.Material.Filled.Description" />
            <MudText Typo="Typo.h6">SDP — @Stream.Name</MudText>
        </div>
    </TitleContent>
    <DialogContent>
        <MudSimpleTable Dense="true" Hover="true" Bordered="true" Class="mb-4">
            <thead>
                <tr>
                    <th style="width:140px;">Field</th>
                    <th>Value</th>
                </tr>
            </thead>
            <tbody>
                <tr>
                    <td><strong>Session Name</strong></td>
                    <td>@Stream.Name</td>
                </tr>
                @if (!string.IsNullOrEmpty(Stream.Description))
                {
                    <tr>
                        <td><strong>Description</strong></td>
                        <td>@Stream.Description</td>
                    </tr>
                }
                <tr>
                    <td><strong>Origin</strong></td>
                    <td><code>@Stream.Origin</code></td>
                </tr>
                <tr>
                    <td><strong>Multicast</strong></td>
                    <td><code>@Stream.MulticastGroup</code></td>
                </tr>
                @if (!string.IsNullOrEmpty(Stream.SourceAddress))
                {
                    <tr>
                        <td><strong>Source (SSM)</strong></td>
                        <td><code>@Stream.SourceAddress</code></td>
                    </tr>
                }
                <tr>
                    <td><strong>Port</strong></td>
                    <td>@Stream.Port</td>
                </tr>
                <tr>
                    <td><strong>Codec</strong></td>
                    <td>@Stream.Codec</td>
                </tr>
                <tr>
                    <td><strong>Sample Rate</strong></td>
                    <td>@(Stream.SampleRate) Hz</td>
                </tr>
                <tr>
                    <td><strong>Channels</strong></td>
                    <td>@Stream.Channels</td>
                </tr>
                @if (Stream.ChannelLabels.Count > 0)
                {
                    <tr>
                        <td><strong>Channel Labels</strong></td>
                        <td>
                            @for (int i = 0; i < Stream.ChannelLabels.Count; i++)
                            {
                                <MudChip T="string" Size="Size.Small" Variant="Variant.Outlined" Color="Color.Primary" Class="mr-1 mb-1">
                                    @(i + 1): @Stream.ChannelLabels[i]
                                </MudChip>
                            }
                        </td>
                    </tr>
                }
                <tr>
                    <td><strong>Bit Depth</strong></td>
                    <td>@Stream.BitDepth</td>
                </tr>
                <tr>
                    <td><strong>Payload Type</strong></td>
                    <td>@Stream.PayloadType</td>
                </tr>
                @if (Stream.PtimeMs > 0)
                {
                    <tr>
                        <td><strong>ptime</strong></td>
                        <td>@(Stream.PtimeMs) ms</td>
                    </tr>
                }
                <tr>
                    <td><strong>Source</strong></td>
                    <td>
                        @if (Stream.IsManual)
                        {
                            <MudChip T="string" Size="Size.Small" Color="Color.Info">Uploaded</MudChip>
                        }
                        else
                        {
                            <MudChip T="string" Size="Size.Small" Color="Color.Success">SAP</MudChip>
                        }
                    </td>
                </tr>
            </tbody>
        </MudSimpleTable>

        <MudText Typo="Typo.subtitle2" Class="mb-1">Raw SDP</MudText>
        <MudPaper Elevation="0" Class="pa-3 rounded" Style="background-color: var(--mud-palette-surface); border: 1px solid var(--mud-palette-lines-default); max-height: 350px; overflow-y: auto;">
            <pre style="margin:0; font-size: 0.82em; white-space: pre-wrap; word-break: break-all;">@Stream.RawSdp</pre>
        </MudPaper>
    </DialogContent>
    <DialogActions>
        <MudButton OnClick="Cancel">Close</MudButton>
    </DialogActions>
</MudDialog>

@code {
    [CascadingParameter]
    private IMudDialogInstance MudDialog { get; set; } = default!;

    [Parameter]
    public DiscoveredStream Stream { get; set; } = default!;

    private void Cancel() => MudDialog.Close(DialogResult.Cancel());
}
