{
  "Logging": {
    "LogLevel": {
      "Default": "Information",
      "Microsoft.AspNetCore": "Warning"
    }
  },
  "AllowedHosts": "*",
  "RtpListener": {
    "Port": 5004,
    "MulticastGroup": "",
    "LocalAddress": "0.0.0.0",
    "SampleRate": 48000,
    "Channels": 1,
    "PacketsPerChunk": 10,
    "ForceBitDepth": 0
  },
  "SapListener": {
    "Enabled": true,
    "MulticastGroup": "239.255.255.255",
    "Port": 9875,
    "LocalAddress": "0.0.0.0",
    "ExpirySeconds": 300
  },
  "Recording": {
    "OutputDirectory": "Recordings",
    "SilencePacketThreshold": 100,
    "NoPacketTimeoutMs": 1000,
    "MaxBufferSizeBytes": 10485760
  }
}
